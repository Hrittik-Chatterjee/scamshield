---
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.tsx';

const stats = [
  { label: 'Scam Reports', value: '2,841' },
  { label: 'Shops Flagged', value: '934' },
  { label: 'Buyers Warned', value: '12,000+' },
  { label: 'Sellers Protected', value: '480+' },
];

const recentScams = [
  { name: 'TrendyClosetBD', type: 'Shop', risk: 'high', reports: 14, date: '2 hours ago' },
  { name: '01987-654321', type: 'bKash', risk: 'confirmed', reports: 7, date: '5 hours ago' },
  { name: 'facebook.com/fashionhub99', type: 'Facebook Page', risk: 'caution', reports: 3, date: '1 day ago' },
  { name: 'GadgetKingBD', type: 'Shop', risk: 'confirmed', reports: 22, date: '2 days ago' },
];

const riskConfig = {
  confirmed: { label: 'CONFIRMED SCAM', color: 'var(--color-danger)', bg: 'rgba(230,57,70,0.08)', border: 'rgba(230,57,70,0.2)' },
  high:      { label: 'HIGH RISK',      color: 'var(--color-danger)', bg: 'rgba(230,57,70,0.05)', border: 'rgba(230,57,70,0.15)' },
  caution:   { label: 'CAUTION',        color: 'var(--color-caution)', bg: 'rgba(255,214,10,0.05)', border: 'rgba(255,214,10,0.2)' },
  safe:      { label: 'SAFE',           color: 'var(--color-safe)', bg: 'rgba(6,214,160,0.05)', border: 'rgba(6,214,160,0.2)' },
} as const;
---

<Layout title="ScamShield BD — Verify Before You Pay" description="Bangladesh's #1 scam verification platform. Check any Facebook shop, bKash number, or online store before sending money.">

  <!-- Hero Section -->
  <section style="padding: clamp(48px, 8vw, 100px) 16px 0; text-align: center; position: relative; overflow: hidden;">

    <div style="position: absolute; inset: 0; background-image: radial-gradient(circle at 50% 0%, rgba(179,0,0,0.03) 0%, transparent 70%); pointer-events: none;"></div>
    <div style="position: absolute; inset: 0; background-image: linear-gradient(rgba(25,25,33,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(25,25,33,0.05) 1px, transparent 1px); background-size: 40px 40px; pointer-events: none; mask-image: radial-gradient(ellipse at 50% 0%, black 0%, transparent 70%);"></div>

    <div style="position: relative; z-index: 1; max-width: 800px; margin: 0 auto;">

      <!-- Badge -->
      <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(179,0,0,0.05); border: 1px solid rgba(179,0,0,0.12); border-radius: 9999px; margin-bottom: 28px; padding: 6px 16px;">
        <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--color-danger); animation: pulse-ring 2s infinite;"></span>
        <span style="font-size: 12px; color: var(--color-danger); font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase;">Bangladesh's Scam Alert Network</span>
      </div>

      <!-- Headline -->
      <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; margin: 0 0 20px; color: var(--color-text-primary);">
        Know Before You Pay.<br/>
        <span style="color: var(--color-danger);">Don't Be the Next Victim.</span>
      </h1>

      <!-- Sub-headline -->
      <p style="font-size: clamp(1rem, 2vw, 1.15rem); color: var(--color-text-secondary); max-width: 560px; margin: 0 auto 40px; line-height: 1.6;">
        Search any Facebook shop, bKash/Nagad number, or online store — get an instant fraud history and AI risk assessment in seconds.
      </p>

      <!-- Search Bar Island -->
      <SearchBar client:only="react" />

    </div>
  </section>

  <!-- Stats Bar -->
  <section style="max-width: 900px; margin: 64px auto 0; padding: 0 16px;">
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--color-border); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--color-border);">
      {stats.map((stat) => (
        <div style="background: var(--color-surface); padding: 28px; text-align: center;">
          <div style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--color-text-primary); font-family: var(--font-mono); letter-spacing: -0.03em;">{stat.value}</div>
          <div style="font-size: 13px; color: var(--color-text-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.05em;">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- How It Works -->
  <section style="max-width: 900px; margin: 80px auto 0; padding: 0 16px;">
    <h2 style="font-size: 1.5rem; font-weight: 700; text-align: center; margin-bottom: 40px; color: var(--color-text-primary);">How ScamShield Works</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px;">
      {[
        { icon: '🔍', step: '01', title: 'Search Instantly', desc: 'Type a shop name, page link, or bKash number. Results load in under 2 seconds.' },
        { icon: '🤖', step: '02', title: 'AI Scans the Web', desc: 'If not in our database, our AI checks domain age, Safe Browsing, and web reviews automatically.' },
        { icon: '✅', step: '03', title: 'See Risk Verdict', desc: 'Get a clear risk rating — Safe, Caution, High Risk, or Confirmed Scam — before you pay.' },
        { icon: '📢', step: '04', title: 'Report & Protect', desc: 'Victim? Submit a report with evidence. It helps protect thousands of other shoppers.' },
      ].map(item => (
        <div style="background: var(--color-card); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 24px; transition: border-color 0.2s;" onmouseover="this.style.borderColor='var(--color-border-light)'" onmouseout="this.style.borderColor='var(--color-border)'">
          <div style="font-size: 24px; margin-bottom: 12px;">{item.icon}</div>
          <div style="font-size: 11px; font-family: var(--font-mono); color: var(--color-danger); letter-spacing: 0.1em; margin-bottom: 8px;">{item.step}</div>
          <div style="font-size: 15px; font-weight: 600; color: var(--color-text-primary); margin-bottom: 8px;">{item.title}</div>
          <div style="font-size: 13px; color: var(--color-text-secondary); line-height: 1.5;">{item.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Recent Reports -->
  <section style="max-width: 900px; margin: 80px auto 0; padding: 0 16px;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--color-text-primary); margin: 0;">Recent Verified Reports</h2>
      <span style="font-size: 12px; color: var(--color-text-muted);">Updated continuously</span>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px;">
      {recentScams.map((scam) => {
        const risk = riskConfig[scam.risk as keyof typeof riskConfig];
        return (
          <a href={`/search?q=${encodeURIComponent(scam.name)}&mode=buyer`} style="display: flex; align-items: center; gap: 16px; background: var(--color-card); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 16px 20px; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.background='var(--color-card-hover)'; this.style.borderColor='var(--color-border-light)'" onmouseout="this.style.background='var(--color-card)'; this.style.borderColor='var(--color-border)'">
            <span style={`font-size: 10px; font-weight: 700; letter-spacing: 0.08em; padding: 3px 8px; border-radius: 4px; white-space: nowrap; background: ${risk.bg}; color: ${risk.color}; border: 1px solid ${risk.border};`}>
              {risk.label}
            </span>
            <span style="font-family: var(--font-mono); font-size: 13px; color: var(--color-text-primary); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{scam.name}</span>
            <span style="font-size: 12px; color: var(--color-text-muted); white-space: nowrap;">{scam.type}</span>
            <span style="font-size: 12px; color: var(--color-danger); white-space: nowrap; font-weight: 500;">{scam.reports} report{scam.reports !== 1 ? 's' : ''}</span>
            <span style="font-size: 11px; color: var(--color-text-muted); white-space: nowrap; display: none;" class="sm:inline">{scam.date}</span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- For Sellers CTA -->
  <section style="max-width: 900px; margin: 80px auto 0; padding: 0 16px;">
    <div style="background: linear-gradient(135deg, rgba(123,104,238,0.08) 0%, rgba(123,104,238,0.03) 100%); border: 1px solid rgba(123,104,238,0.2); border-radius: var(--radius-xl); padding: clamp(28px, 4vw, 48px); display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 24px;">
      <div>
        <div style="font-size: 11px; font-weight: 600; letter-spacing: 0.1em; color: var(--color-accent); text-transform: uppercase; margin-bottom: 10px;">FOR BUSINESS OWNERS</div>
        <h3 style="font-size: clamp(1.1rem, 2.5vw, 1.5rem); font-weight: 700; color: var(--color-text-primary); margin: 0 0 10px;">Tired of Fake COD Orders?</h3>
        <p style="font-size: 14px; color: var(--color-text-secondary); margin: 0; max-width: 480px; line-height: 1.5;">
          Check a buyer's phone number before accepting their order. Our seller registry tracks repeat delivery-refusal scammers so you don't get burned.
        </p>
      </div>
      <a href="/?mode=seller" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; background: var(--color-accent); color: white; text-decoration: none; border-radius: var(--radius-pill); font-size: 14px; font-weight: 600; white-space: nowrap; transition: all 0.2s; box-shadow: 0 4px 16px rgba(123,104,238,0.3);" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
        🏪 Check a Buyer →
      </a>
    </div>
  </section>

</Layout>

<style>
  @media (min-width: 640px) {
    [style*="grid-template-columns: repeat(2"] {
      grid-template-columns: repeat(4, 1fr) !important;
    }
  }
</style>
