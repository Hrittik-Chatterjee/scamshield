---
import Layout from '../layouts/Layout.astro';

// Read reference ID from search parameter
const refId = Astro.url.searchParams.get('ref') ?? 'UNKNOWN';
---

<Layout title="Report Submitted Successfully — ScamShield BD" description="Your report has been successfully submitted and is queued for verification.">

  <div style="max-width: 540px; margin: 64px auto; padding: 0 16px; text-align: center;">
    <div style="background: var(--color-card); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 48px 32px; box-shadow: 0 8px 32px rgba(0,0,0,0.05);">
      
      <!-- Checkmark Animation/Icon -->
      <div style="width: 72px; height: 72px; background: rgba(6, 214, 160, 0.08); border: 2.5px solid var(--color-safe); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32px; margin: 0 auto 24px;">
        ✓
      </div>

      <div style="font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: var(--color-safe); text-transform: uppercase; margin-bottom: 12px;">
        Submission Success
      </div>

      <h1 style="font-size: 24px; font-weight: 700; color: var(--color-text-primary); margin: 0 0 16px;">
        Thank You for Reporting!
      </h1>

      <p style="font-size: 14px; color: var(--color-text-secondary); line-height: 1.6; margin: 0 auto 28px; max-width: 420px;">
        Your report has been received and is currently under review by our administrators. Once verified, the details will appear in public searches to help protect others.
      </p>

      <!-- Reference Box -->
      <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 18px; display: inline-block; margin-bottom: 32px; min-width: 240px;">
        <div style="font-size: 11px; color: var(--color-text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.05em;">Your Reference ID</div>
        <div style="font-size: 20px; font-weight: 700; font-family: var(--font-mono); color: var(--color-text-primary);">
          #{refId.toUpperCase()}
        </div>
      </div>

      <!-- Action Buttons -->
      <div style="display: flex; flex-direction: column; gap: 12px; max-width: 320px; margin: 0 auto;">
        <a href="/" style="display: block; padding: 14px 24px; background: var(--color-danger); color: white; border-radius: var(--radius-pill); font-size: 14px; font-weight: 600; text-decoration: none; box-shadow: 0 4px 16px rgba(230,57,70,0.3); transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          ← Back to Home / Search
        </a>
        <a href="/report" style="display: block; padding: 14px 24px; background: transparent; color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-pill); font-size: 14px; font-weight: 500; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.background='var(--color-surface)'" onmouseout="this.style.background='transparent'">
          File Another Report
        </a>
      </div>

    </div>
  </div>

</Layout>
