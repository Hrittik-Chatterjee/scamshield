---
import Layout from '../../layouts/Layout.astro';

const ADMIN_KEY = import.meta.env.ADMIN_SECRET_KEY ?? 'dev-admin-key-change-in-production';

// Auth check via ?key= query param
const providedKey = Astro.url.searchParams.get('key') ?? '';
const authed = providedKey === ADMIN_KEY;

// If not authed, show login prompt (no redirect — just show the form)
---

<Layout title="Admin Dashboard — ScamShield BD">

  {!authed ? (
    <!-- Login Gate -->
    <div style="max-width: 420px; margin: 80px auto; padding: 0 16px;">
      <div style="background: var(--color-card); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 40px;">
        <div style="text-align: center; margin-bottom: 32px;">
          <div style="width: 48px; height: 48px; background: var(--color-danger); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-size: 20px; margin: 0 auto 16px; box-shadow: 0 0 20px rgba(230,57,70,0.3);">🔐</div>
          <h1 style="font-size: 1.3rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 6px;">Admin Access</h1>
          <p style="font-size: 13px; color: var(--color-text-muted); margin: 0;">ScamShield BD — Review Dashboard</p>
        </div>
        <form method="get" action="/admin">
          <label style="display: block; font-size: 12px; font-weight: 600; color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px;">Admin Key</label>
          <input
            id="admin-key-input"
            type="password"
            name="key"
            placeholder="Enter admin secret key"
            style="width: 100%; background: var(--color-surface); border: 1.5px solid var(--color-border); border-radius: var(--radius-md); padding: 12px 14px; font-size: 14px; color: var(--color-text-primary); font-family: var(--font-mono); outline: none; box-sizing: border-box; margin-bottom: 16px;"
          />
          <button
            type="submit"
            id="admin-login-btn"
            style="width: 100%; padding: 13px; background: var(--color-danger); color: white; border: none; border-radius: var(--radius-pill); font-size: 14px; font-weight: 600; cursor: pointer; font-family: var(--font-sans); box-shadow: 0 4px 16px rgba(230,57,70,0.3);"
          >
            Access Dashboard →
          </button>
        </form>
        {providedKey && !authed && (
          <p style="margin-top: 16px; text-align: center; font-size: 13px; color: var(--color-danger);">⚠ Incorrect key</p>
        )}
      </div>
    </div>
  ) : (
    <!-- Admin Dashboard -->
    <div style="max-width: 960px; margin: 0 auto; padding: 40px 16px;" id="admin-dashboard">

      <!-- Header -->
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px; flex-wrap: wrap; gap: 16px;">
        <div>
          <div style="font-size: 11px; font-weight: 700; letter-spacing: 0.1em; color: var(--color-danger); text-transform: uppercase; margin-bottom: 6px;">Admin Dashboard</div>
          <h1 style="font-size: 1.6rem; font-weight: 700; color: var(--color-text-primary); margin: 0;">Report Review Queue</h1>
        </div>
        <div style="display: flex; gap: 10px;">
          <button id="filter-pending" onclick="filterReports('PENDING')" style="padding: 8px 16px; background: var(--color-danger); color: white; border: none; border-radius: var(--radius-pill); font-size: 13px; font-weight: 600; cursor: pointer; font-family: var(--font-sans);">Pending</button>
          <button id="filter-approved" onclick="filterReports('APPROVED')" style="padding: 8px 16px; background: var(--color-surface); color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-pill); font-size: 13px; cursor: pointer; font-family: var(--font-sans);">Approved</button>
          <button id="filter-rejected" onclick="filterReports('REJECTED')" style="padding: 8px 16px; background: var(--color-surface); color: var(--color-text-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-pill); font-size: 13px; cursor: pointer; font-family: var(--font-sans);">Rejected</button>
        </div>
      </div>

      <!-- Stats Row -->
      <div id="admin-stats" class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-7">
        <div style="background: var(--color-card); border: 1px solid var(--color-border); border-radius: var(--radius-md);" class="p-4 sm:p-5 text-center">
          <div id="stat-pending" style="font-size: 2rem; font-weight: 700; color: var(--color-caution); font-family: var(--font-mono);">—</div>
          <div style="font-size: 12px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Pending</div>
        </div>
        <div style="background: var(--color-card); border: 1px solid var(--color-border); border-radius: var(--radius-md);" class="p-4 sm:p-5 text-center">
          <div id="stat-approved" style="font-size: 2rem; font-weight: 700; color: var(--color-safe); font-family: var(--font-mono);">—</div>
          <div style="font-size: 12px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Approved</div>
        </div>
        <div style="background: var(--color-card); border: 1px solid var(--color-border); border-radius: var(--radius-md);" class="p-4 sm:p-5 text-center">
          <div id="stat-rejected" style="font-size: 2rem; font-weight: 700; color: var(--color-text-muted); font-family: var(--font-mono);">—</div>
          <div style="font-size: 12px; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 4px;">Rejected</div>
        </div>
      </div>

      <!-- AI Retry Queue Banner -->
      <div id="ai-retry-banner" style="display:none; background: rgba(245, 158, 11, 0.08); border: 1px solid rgba(245, 158, 11, 0.3); border-radius: 12px; padding: 16px 20px; margin-bottom: 24px; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;">
        <div style="display:flex; align-items:center; gap:10px;">
          <span style="font-size: 20px;">⚠️</span>
          <div>
            <h4 style="font-size: 14px; font-weight: 600; color: #b45309; margin: 0 0 2px; font-family: var(--font-sans);">Failed AI Classifications</h4>
            <p style="font-size: 12px; color: #78350f; margin: 0; font-family: var(--font-sans);" id="ai-retry-text">There are 0 scraped posts waiting for AI classification review.</p>
          </div>
        </div>
        <button id="run-ai-retry-btn" onclick="window.runAiRetry()" style="padding: 8px 16px; background: #d97706; color: white; border: none; border-radius: var(--radius-pill); font-size: 12px; font-weight: 600; cursor: pointer; font-family: var(--font-sans); transition: background 0.2s;" onmouseover="this.style.background='#b45309'" onmouseout="this.style.background='#d97706'">
          Run AI Review Now
        </button>
      </div>

      <!-- Report Cards Container -->
      <div id="reports-container">
        <div style="text-align: center; padding: 48px; color: var(--color-text-muted);">Loading reports…</div>
      </div>

      <!-- Lightbox Modal -->
      <div id="image-lightbox" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.92);z-index:999999;align-items:center;justify-content:center;cursor:pointer;user-select:none;" onclick="window.closeLightbox()">
        <!-- Close button -->
        <span style="position:absolute;top:24px;right:24px;color:white;font-size:36px;font-weight:bold;cursor:pointer;user-select:none;transition:opacity 0.2s;z-index:10;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">&times;</span>
        
        <!-- Prev Button -->
        <button id="lightbox-prev" style="display:none;position:absolute;left:24px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.12);color:white;border:none;border-radius:50%;width:56px;height:56px;align-items:center;justify-content:center;font-size:32px;cursor:pointer;z-index:10;transition:all 0.2s;font-weight:300;" onclick="window.prevImage(event)" onmouseover="this.style.background='rgba(255,255,255,0.22)';this.style.transform='translateY(-50%) scale(1.05)';" onmouseout="this.style.background='rgba(255,255,255,0.12)';this.style.transform='translateY(-50%) scale(1)';">
          &lsaquo;
        </button>
        
        <!-- Image element -->
        <img id="lightbox-img" src="" style="max-width:85%;max-height:85%;object-fit:contain;border-radius:12px;box-shadow:0 16px 64px rgba(0,0,0,0.85);cursor:default;transition:all 0.2s;" onclick="event.stopPropagation()" />
        
        <!-- Next Button -->
        <button id="lightbox-next" style="display:none;position:absolute;right:24px;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.12);color:white;border:none;border-radius:50%;width:56px;height:56px;align-items:center;justify-content:center;font-size:32px;cursor:pointer;z-index:10;transition:all 0.2s;font-weight:300;" onclick="window.nextImage(event)" onmouseover="this.style.background='rgba(255,255,255,0.22)';this.style.transform='translateY(-50%) scale(1.05)';" onmouseout="this.style.background='rgba(255,255,255,0.12)';this.style.transform='translateY(-50%) scale(1)';">
          &rsaquo;
        </button>
        
        <!-- Counter info -->
        <div id="lightbox-counter" style="display:none;position:absolute;bottom:28px;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.85);font-size:13px;font-weight:600;background:rgba(25,25,30,0.75);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.15);padding:6px 16px;border-radius:30px;font-family:system-ui, -apple-system, sans-serif;"></div>
      </div>

    </div>
  )}

</Layout>

{authed && (
  <script define:vars={{ adminKey: providedKey }}>
    let currentFilter = 'PENDING';

    async function fetchStats() {
      for (const status of ['PENDING', 'APPROVED', 'REJECTED']) {
        try {
          const res = await fetch(`/api/admin/queue?key=${adminKey}&status=${status}`);
          const data = await res.json();
          const el = document.getElementById(`stat-${status.toLowerCase()}`);
          if (el) el.textContent = data.total ?? 0;
        } catch {}
      }
    }

    async function filterReports(status) {
      currentFilter = status;
      ['pending','approved','rejected'].forEach(s => {
        const btn = document.getElementById(`filter-${s}`);
        if (btn) {
          btn.style.background = s.toUpperCase() === status ? 'var(--color-danger)' : 'var(--color-surface)';
          btn.style.color = s.toUpperCase() === status ? 'white' : 'var(--color-text-secondary)';
          btn.style.border = s.toUpperCase() === status ? 'none' : '1px solid var(--color-border)';
        }
      });
      await loadReports(status);
    }

    async function loadReports(status = 'PENDING') {
      const container = document.getElementById('reports-container');
      if (!container) return;
      container.innerHTML = '<div style="text-align: center; padding: 48px; color: var(--color-text-muted);">Loading…</div>';
      try {
        const res = await fetch(`/api/admin/queue?key=${adminKey}&status=${status}`);
        const data = await res.json();
        
        // ── AI Retry Queue Check ──
        if (status === 'PENDING' && data.reports) {
          checkAiFailedReports(data.reports);
        } else {
          const banner = document.getElementById('ai-retry-banner');
          if (banner) banner.style.display = 'none';
        }

        if (!data.reports || data.reports.length === 0) {
          container.innerHTML = `<div style="text-align: center; padding: 48px; color: var(--color-text-muted);">No ${status.toLowerCase()} reports.</div>`;
          return;
        }
        container.innerHTML = data.reports.map(r => renderCard(r)).join('');
      } catch (e) {
        container.innerHTML = '<div style="text-align: center; padding: 48px; color: var(--color-danger);">Failed to load reports.</div>';
      }
    }

    function parseScrapedComplaint(text) {
      const result = {
        originalUrl: '',
        posterName: '',
        posterProfile: '',
        caption: text || '',
        photos: []
      };

      if (!text) return result;

      // 1. Try JSON Parsing first
      const trimmed = text.trim();
      if (trimmed.startsWith('{') && trimmed.endsWith('}')) {
        try {
          const parsed = JSON.parse(trimmed);
          if (parsed.scraped) {
            result.originalUrl = parsed.postUrl || '';
            result.posterName = parsed.posterName || '';
            result.posterProfile = parsed.posterUrl || '';
            result.caption = parsed.postText || '';
            result.photos = parsed.images || [];
            return result;
          }
        } catch (e) {
          console.error("JSON parse failed, falling back to regex", e);
        }
      }

      // 2. Fallback to Regex Parser (normalized CRLF to LF)
      const normalized = text.replace(/\r\n/g, '\n').trim();
      if (!normalized.includes('[Scraped from')) {
        return result;
      }

      // Extract Original Post URL
      const postUrlMatch = normalized.match(/\[Scraped from [^\]]+\] \((https?:\/\/[^\)]+)\)/);
      if (postUrlMatch) {
        result.originalUrl = postUrlMatch[1];
      }

      // Extract Poster Name
      const posterNameMatch = normalized.match(/Poster: ([^\n]+)/);
      if (posterNameMatch) {
        result.posterName = posterNameMatch[1].trim();
      }

      // Extract Poster Profile URL
      const posterProfileMatch = normalized.match(/Poster Profile: ([^\n]+)/);
      if (posterProfileMatch) {
        result.posterProfile = posterProfileMatch[1].trim();
      }

      // Extract Captured Photos
      const photoRegex = /Photo \d+: (https?:\/\/[^\s\n]+)/g;
      let match;
      while ((match = photoRegex.exec(normalized)) !== null) {
        result.photos.push(match[1]);
      }

      // Extract actual caption
      let captionText = normalized;
      captionText = captionText.replace(/\[Scraped from [^\]]+\] \([^\)]+\)\n?/, '');
      captionText = captionText.replace(/Poster: [^\n]+\n?/, '');
      captionText = captionText.replace(/Poster Profile: [^\n]+\n?/, '');
      captionText = captionText.replace(/--- Captured Photos ---[\s\S]*$/, '');
      captionText = captionText.replace(/--- Visible Comments ---[\s\S]*$/, '');

      result.caption = captionText.trim();
      return result;
    }

    function renderCard(r) {
      const typeColor = r.reporterType === 'BUYER' ? 'var(--color-danger)' : 'var(--color-accent)';
      const typeBg   = r.reporterType === 'BUYER' ? 'rgba(230,57,70,0.08)' : 'rgba(123,104,238,0.08)';
      const typeBorder = r.reporterType === 'BUYER' ? 'rgba(230,57,70,0.2)' : 'rgba(123,104,238,0.2)';
      const typeLabel  = r.reporterType === 'BUYER' ? '🛒 Buyer Report' : '🏪 Seller Report';
      const date = new Date(r.createdAt).toLocaleString('en-BD', { dateStyle: 'medium', timeStyle: 'short' });

      // Clean display for Entity identifier
      const isEntityLink = r.entityIdentifier && r.entityIdentifier.startsWith('http');
      const entityDisplay = isEntityLink
        ? `<a href="${r.entityIdentifier}" target="_blank" style="color:var(--color-accent);font-weight:600;text-decoration:none;word-break:break-all;">${r.entityIdentifier.replace(/https?:\/\/(www\.)?facebook\.com\//, '')} ↗</a>`
        : r.entityIdentifier;

      const isLink = r.evidenceFileName && r.evidenceFileName.startsWith('http');
      const isR2Key = r.evidenceFileName && !isLink && !r.evidenceDataUrl;
      const displayImgUrl = r.evidenceDataUrl || (isR2Key ? `/api/evidence?key=${encodeURIComponent(r.evidenceFileName)}` : '');

      // Parse scraped posts if applicable to extract photoUrls first
      const trimmedText = (r.complaintText || '').trim();
      const isScraped = trimmedText.startsWith('[Scraped from') || (trimmedText.startsWith('{') && trimmedText.endsWith('}'));
      let complaintContent = r.complaintText;
      let posterNameHtml = '';
      let photoUrls = [];

      if (isScraped) {
        const parsed = parseScrapedComplaint(r.complaintText);
        complaintContent = parsed.caption || '(No caption)';
        photoUrls = parsed.photos;

        if (parsed.posterName) {
          const isAnon = parsed.posterName.toLowerCase().includes('anonymous') || parsed.posterName.toLowerCase().includes('অনামী');
          const nameDisplay = isAnon ? '👥 Anonymous User' : parsed.posterName;
          
          if (parsed.posterProfile && !isAnon) {
            posterNameHtml = `<div><div style="font-size:11px;color:var(--color-text-muted);margin-bottom:3px;">POSTER</div><div style="font-size:14px;color:var(--color-text-primary);font-weight:600;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><a href="${parsed.posterProfile}" target="_blank" style="color:var(--color-accent);text-decoration:none;" title="${parsed.posterName}">${nameDisplay} ↗</a></div></div>`;
          } else {
            posterNameHtml = `<div><div style="font-size:11px;color:var(--color-text-muted);margin-bottom:3px;">POSTER</div><div style="font-size:14px;color:var(--color-text-primary);font-weight:600;">${nameDisplay}</div></div>`;
          }
        }
      } else {
        const photoRegex = /Photo \d+: (https?:\/\/[^\s\n]+)/g;
        let match;
        while ((match = photoRegex.exec(r.complaintText)) !== null) {
          photoUrls.push(match[1]);
        }
      }

      // Collect all images for the lightbox group of this card
      const allCardImages = [];
      if (displayImgUrl) {
        allCardImages.push(displayImgUrl);
      }
      photoUrls.forEach(url => {
        const isAbsolute = url.startsWith('http') || url.startsWith('data:');
        const renderUrl = isAbsolute ? url : `/api/evidence?key=${encodeURIComponent(url)}`;
        allCardImages.push(renderUrl);
      });
      const allCardImagesJson = JSON.stringify(allCardImages).replace(/"/g, '&quot;');

      const imgHtml = displayImgUrl
        ? `<img src="${displayImgUrl}" alt="Evidence" style="max-width:100%;max-height:240px;border-radius:8px;border:1px solid var(--color-border);display:block;margin-top:12px;cursor:pointer;" onclick="window.openLightbox('${displayImgUrl}', ${allCardImagesJson})" title="Click to view full size" />`
        : isLink
          ? `<div style="padding:16px;background:var(--color-surface);border-radius:8px;font-size:13px;margin-top:12px;">📎 <a href="${r.evidenceFileName}" target="_blank" style="color:var(--color-accent);font-weight:600;text-decoration:none;">Open Scraped Post Link ↗</a></div>`
          : `<div style="padding:16px;background:var(--color-surface);border-radius:8px;font-size:13px;color:var(--color-text-muted);margin-top:12px;">📎 ${r.evidenceFileName}</div>`;

      let photosHtml = '';
      if (photoUrls.length > 0) {
        photosHtml = `
          <div style="margin-top:12px;">
            <div style="font-size:11px;color:var(--color-text-muted);margin-bottom:6px;">SCRAPED PHOTOS (${photoUrls.length})</div>
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
              ${photoUrls.map((url, index) => {
                const isAbsolute = url.startsWith('http') || url.startsWith('data:');
                const renderUrl = isAbsolute ? url : `/api/evidence?key=${encodeURIComponent(url)}`;
                return `
                  <div style="position:relative;border:1px solid var(--color-border);border-radius:8px;overflow:hidden;background:var(--color-surface);">
                    <img src="${renderUrl}" referrerpolicy="no-referrer" alt="Scraped Photo ${index + 1}" style="height:100px;max-width:180px;object-fit:cover;display:block;cursor:pointer;" onclick="window.openLightbox('${renderUrl}', ${allCardImagesJson})" title="Click to view full size" />
                  </div>
                `;
              }).join('')}
            </div>
          </div>
        `;
      }

      const actionBtns = `
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          ${r.status === 'PENDING' ? `
            <button onclick="reviewReport('${r.id}','approve')" style="padding:8px 16px;background:var(--color-safe);color:white;border:none;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;font-family:sans-serif;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">✓ Approve</button>
            <button onclick="reviewReport('${r.id}','reject')" style="padding:8px 16px;background:transparent;color:var(--color-danger);border:1px solid rgba(230,57,70,0.4);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;font-family:sans-serif;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">✗ Reject</button>
          ` : `
            <span style="font-size:12px;font-weight:700;color:${r.status==='APPROVED'?'var(--color-safe)':'var(--color-text-muted)'};text-transform:uppercase;letter-spacing:0.05em;">${r.status==='APPROVED'?'✓ Approved':'✗ Rejected'}</span>
          `}
          <button onclick="reviewReport('${r.id}','delete')" style="padding:8px 16px;background:rgba(230,57,70,0.06);color:var(--color-danger);border:1.5px dashed rgba(230,57,70,0.4);border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;font-family:sans-serif;transition:all 0.2s;display:inline-flex;align-items:center;gap:4px;" onmouseover="this.style.background='var(--color-danger)';this.style.color='white';this.style.borderStyle='solid';" onmouseout="this.style.background='rgba(230,57,70,0.06)';this.style.color='var(--color-danger)';this.style.borderStyle='dashed';">
            🗑 Delete
          </button>
        </div>
      `;

      return `
        <div id="card-${r.id}" style="background:var(--color-card);border:1px solid var(--color-border);border-radius:16px;" class="p-4 sm:p-6 mb-4">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-4">
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
              <span style="font-size:10px;font-weight:700;letter-spacing:0.06em;padding:3px 10px;border-radius:4px;background:${typeBg};color:${typeColor};border:1px solid ${typeBorder};">${typeLabel}</span>
              <span style="font-size:11px;color:var(--color-text-muted);">#${r.id.slice(0,8).toUpperCase()}</span>
              <span style="font-size:11px;color:var(--color-text-muted);">${date}</span>
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">${actionBtns}</div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mb-4">
            <div><div style="font-size:11px;color:var(--color-text-muted);margin-bottom:3px;">ENTITY</div><div style="font-size:14px;color:var(--color-text-primary);font-weight:600;word-break:break-all;">${entityDisplay}</div></div>
            <div><div style="font-size:11px;color:var(--color-text-muted);margin-bottom:3px;">TYPE</div><div style="font-size:13px;color:var(--color-text-secondary);">${r.entityType}</div></div>
            ${posterNameHtml}
            <div><div style="font-size:11px;color:var(--color-text-muted);margin-bottom:3px;">INCIDENT DATE</div><div style="font-size:13px;color:var(--color-text-secondary);">${r.incidentDate}</div></div>
            ${r.amountLost ? `<div><div style="font-size:11px;color:var(--color-text-muted);margin-bottom:3px;">AMOUNT LOST</div><div style="font-size:13px;color:var(--color-danger);font-weight:600;">৳${r.amountLost.toLocaleString()}</div></div>` : ''}
          </div>
          <div style="background:var(--color-surface);border-radius:8px;padding:14px;margin-bottom:12px;">
            <div style="font-size:11px;color:var(--color-text-muted);margin-bottom:6px;">COMPLAINT</div>
            ${(() => {
              const isLong = complaintContent.length > 300;
              const displayContent = isLong ? complaintContent.substring(0, 300) + '...' : complaintContent;
              const escapedFullText = encodeURIComponent(complaintContent);
              return isLong ? `
                <div style="font-size:14px;color:var(--color-text-primary);line-height:1.6;white-space:pre-wrap;" data-full-text="${escapedFullText}" data-collapsed="true">
                  <span class="complaint-span">${displayContent}</span>
                  <button onclick="window.toggleComplaintExpand(this)" style="background:none;border:none;color:var(--color-accent);font-weight:600;padding:0;margin-left:6px;cursor:pointer;font-family:sans-serif;font-size:13px;text-decoration:underline;display:inline;">See More</button>
                </div>
              ` : `
                <div style="font-size:14px;color:var(--color-text-primary);line-height:1.6;white-space:pre-wrap;">${complaintContent}</div>
              `;
            })()}
          </div>
          ${photosHtml}
          <div style="margin-top:12px;">
            <div style="font-size:11px;color:var(--color-text-muted);margin-bottom:4px;">EVIDENCE</div>
            ${imgHtml}
          </div>
        </div>
      `;
    }

    async function reviewReport(reportId, action) {
      if (action === 'delete' && !confirm('Are you sure you want to permanently delete this report? This will remove all associated records.')) {
        return;
      }
      const card = document.getElementById(`card-${reportId}`);
      if (card) card.style.opacity = '0.5';
      try {
        const res = await fetch('/api/admin/review', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ key: adminKey, reportId, action }),
        });
        const data = await res.json();
        if (data.ok) {
          await fetchStats();
          await loadReports(currentFilter);
        }
      } catch (e) {
        if (card) card.style.opacity = '1';
        alert('Failed to update report. Please try again.');
      }
    }

    let lightboxImages = [];
    let lightboxIndex = 0;

    function openLightbox(src, imageGroup = []) {
      lightboxImages = imageGroup.length > 0 ? imageGroup : [src];
      lightboxIndex = lightboxImages.indexOf(src);
      if (lightboxIndex === -1) lightboxIndex = 0;
      updateLightbox();
    }

    function updateLightbox() {
      const lightbox = document.getElementById('image-lightbox');
      const img = document.getElementById('lightbox-img');
      const prevBtn = document.getElementById('lightbox-prev');
      const nextBtn = document.getElementById('lightbox-next');
      const counter = document.getElementById('lightbox-counter');
      
      if (lightbox && img) {
        img.src = lightboxImages[lightboxIndex];
        lightbox.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        
        if (lightboxImages.length > 1) {
          if (prevBtn) prevBtn.style.display = 'flex';
          if (nextBtn) nextBtn.style.display = 'flex';
          if (counter) {
            counter.style.display = 'block';
            counter.textContent = `${lightboxIndex + 1} / ${lightboxImages.length}`;
          }
        } else {
          if (prevBtn) prevBtn.style.display = 'none';
          if (nextBtn) nextBtn.style.display = 'none';
          if (counter) counter.style.display = 'none';
        }
      }
    }

    function prevImage(e) {
      if (e) e.stopPropagation();
      if (lightboxImages.length <= 1) return;
      lightboxIndex = (lightboxIndex - 1 + lightboxImages.length) % lightboxImages.length;
      updateLightbox();
    }

    function nextImage(e) {
      if (e) e.stopPropagation();
      if (lightboxImages.length <= 1) return;
      lightboxIndex = (lightboxIndex + 1) % lightboxImages.length;
      updateLightbox();
    }

    function closeLightbox() {
      const lightbox = document.getElementById('image-lightbox');
      if (lightbox) {
        lightbox.style.display = 'none';
        document.body.style.overflow = 'auto';
      }
    }

    function toggleComplaintExpand(btn) {
      const container = btn.parentElement;
      const isCollapsed = container.getAttribute('data-collapsed') === 'true';
      const fullText = decodeURIComponent(container.getAttribute('data-full-text'));
      
      if (isCollapsed) {
        container.querySelector('.complaint-span').textContent = fullText;
        container.setAttribute('data-collapsed', 'false');
        btn.textContent = 'See Less';
      } else {
        container.querySelector('.complaint-span').textContent = fullText.substring(0, 300) + '...';
        container.setAttribute('data-collapsed', 'true');
        btn.textContent = 'See More';
      }
    }

    document.addEventListener('keydown', (e) => {
      const lightbox = document.getElementById('image-lightbox');
      if (lightbox && lightbox.style.display === 'flex') {
        if (e.key === 'Escape') {
          closeLightbox();
        } else if (e.key === 'ArrowLeft') {
          prevImage();
        } else if (e.key === 'ArrowRight') {
          nextImage();
        }
      }
    });

    function checkAiFailedReports(reports) {
      let count = 0;
      reports.forEach(r => {
        const trimmed = (r.complaintText || '').trim();
        if (trimmed.startsWith('{') && trimmed.endsWith('}')) {
          try {
            const parsed = JSON.parse(trimmed);
            if (parsed.aiFailed === true) {
              count++;
            }
          } catch {}
        }
      });

      const banner = document.getElementById('ai-retry-banner');
      const text = document.getElementById('ai-retry-text');
      if (banner && text) {
        if (count > 0) {
          text.textContent = `There are ${count} scraped posts waiting for AI classification review.`;
          banner.style.display = 'flex';
        } else {
          banner.style.display = 'none';
        }
      }
    }

    async function runAiRetry() {
      const btn = document.getElementById('run-ai-retry-btn');
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Processing...';
      }
      try {
        const res = await fetch(`/api/admin/retry-ai-classification?key=${adminKey}`, {
          method: 'POST'
        });
        const data = await res.json();
        if (data.ok) {
          alert(`Success! Processed ${data.processedCount} reports.\nReclassified as Scam: ${data.reclassifiedScamCount}\nAuto-Rejected: ${data.reclassifiedRejectedCount}`);
          await fetchStats();
          await loadReports(currentFilter);
        } else {
          alert(data.error || 'Failed to process queue.');
        }
      } catch (err) {
        alert('Failed to connect to the server.');
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.textContent = 'Run AI Review Now';
        }
      }
    }

    // Expose functions globally for HTML onclick handlers
    window.reviewReport = reviewReport;
    window.filterReports = filterReports;
    window.openLightbox = openLightbox;
    window.closeLightbox = closeLightbox;
    window.prevImage = prevImage;
    window.nextImage = nextImage;
    window.toggleComplaintExpand = toggleComplaintExpand;
    window.runAiRetry = runAiRetry;

    // Init
    fetchStats();
    loadReports('PENDING');
  </script>
)}
