---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ScamShield BD — Verify Before You Pay',
  description = 'Bangladesh\'s first AI-powered scam verification platform. Instantly check if a Facebook shop, phone number, or online store is a known fraudster before sending money.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://scamshield.pages.dev');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#ffffff" />
  <link rel="canonical" href={canonicalURL} />
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <!-- Favicon placeholder -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="bg-canvas text-primary">

  <!-- Navigation -->
  <header class="sticky top-0 z-50 border-b" style="background: rgba(255,255,255,0.85); backdrop-filter: blur(16px); border-color: var(--color-border);">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 no-underline group">
        <div class="w-7 h-7 rounded-md flex items-center justify-center text-sm font-bold" style="background: var(--color-danger); color: white; box-shadow: 0 0 12px rgba(179,0,0,0.45);">
          S
        </div>
        <span class="font-semibold tracking-tight" style="color: var(--color-text-primary); font-size: 15px;">
          Scam<span style="color: var(--color-danger);">Shield</span>
          <span class="text-xs font-mono ml-1 px-1 rounded" style="color: var(--color-text-muted); background: var(--color-surface); font-size: 10px; letter-spacing: 0.05em;">BD</span>
        </span>
      </a>

      <!-- Nav Links -->
      <div class="hidden sm:flex items-center gap-6">
        <a href="/" class="text-sm transition-colors" style="color: var(--color-text-secondary);" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-secondary)'">Search</a>
        <a href="/report" class="text-sm transition-colors" style="color: var(--color-text-secondary);" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-secondary)'">Report Fraud</a>
        <a href="/chat" class="text-sm transition-colors" style="color: var(--color-text-secondary);" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-secondary)'">
          <span style="display: inline-flex; align-items: center; gap: 4px;">
            <span style="color: var(--color-danger);">✨</span> ScamShield AI
          </span>
        </a>
        <a href="/about" class="text-sm transition-colors" style="color: var(--color-text-secondary);" onmouseover="this.style.color='var(--color-text-primary)'" onmouseout="this.style.color='var(--color-text-secondary)'">About</a>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2.5">
        <!-- CTA -->
        <a href="/report" class="text-xs font-medium px-3 py-1.5 rounded-full transition-all" style="background: var(--color-danger); color: white; text-decoration: none;" onmouseover="this.style.background='var(--color-danger-dim)'" onmouseout="this.style.background='var(--color-danger)'">
          + Report Scam
        </a>

        <!-- Hamburger Button -->
        <button id="mobile-menu-toggle" class="flex sm:hidden flex-col gap-1 justify-center items-center w-8 h-8 rounded-md border border-default bg-transparent cursor-pointer" aria-label="Toggle mobile menu" style="padding: 0; border-color: var(--color-border);">
          <span class="w-4 h-0.5 transition-all duration-200 origin-center" id="hamburger-line-1" style="background-color: var(--color-text-primary);"></span>
          <span class="w-4 h-0.5 transition-all duration-200" id="hamburger-line-2" style="background-color: var(--color-text-primary);"></span>
          <span class="w-4 h-0.5 transition-all duration-200 origin-center" id="hamburger-line-3" style="background-color: var(--color-text-primary);"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile Navigation Dropdown -->
    <div id="mobile-menu" class="hidden sm:hidden border-t transition-all duration-200 bg-canvas" style="border-color: var(--color-border); max-height: 0; overflow: hidden;">
      <div class="px-4 py-3 flex flex-col gap-3">
        <a href="/" class="text-sm font-medium py-1" style="color: var(--color-text-secondary); text-decoration: none;">Search</a>
        <a href="/report" class="text-sm font-medium py-1" style="color: var(--color-text-secondary); text-decoration: none;">Report Fraud</a>
        <a href="/chat" class="text-sm font-medium py-1" style="color: var(--color-danger); text-decoration: none;">✨ ScamShield AI</a>
        <a href="/about" class="text-sm font-medium py-1" style="color: var(--color-text-secondary); text-decoration: none;">About</a>
      </div>
    </div>
  </header>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const line1 = document.getElementById('hamburger-line-1');
      const line2 = document.getElementById('hamburger-line-2');
      const line3 = document.getElementById('hamburger-line-3');

      if (toggle && menu) {
        let isOpen = false;

        toggle.addEventListener('click', () => {
          isOpen = !isOpen;
          
          if (isOpen) {
            menu.classList.remove('hidden');
            menu.style.maxHeight = '200px';
            // Transform hamburger to X
            line1.style.transform = 'translateY(6px) rotate(45deg)';
            line2.style.opacity = '0';
            line3.style.transform = 'translateY(-6px) rotate(-45deg)';
          } else {
            menu.style.maxHeight = '0';
            // Reset hamburger lines
            line1.style.transform = 'none';
            line2.style.opacity = '1';
            line3.style.transform = 'none';
            setTimeout(() => {
              if (!isOpen) menu.classList.add('hidden');
            }, 200);
          }
        });
      }
    });
  </script>

  <!-- Page Content -->
  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-24 border-t" style="border-color: var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold" style="color: var(--color-text-primary);">Scam<span style="color: var(--color-danger);">Shield</span> BD</span>
          <span class="text-xs" style="color: var(--color-text-muted);">— Free, forever. Protecting Bangladeshi shoppers.</span>
        </div>
        <div class="flex items-center gap-5">
          <a href="/about" class="text-xs" style="color: var(--color-text-muted);">About</a>
          <a href="/report" class="text-xs" style="color: var(--color-text-muted);">Report</a>
          <a href="/privacy" class="text-xs" style="color: var(--color-text-muted);">Privacy</a>
        </div>
      </div>
      <p class="mt-6 text-xs text-center" style="color: var(--color-text-muted);">
        ScamShield BD aggregates community reports and AI analysis for informational purposes only. Always exercise independent judgment.
      </p>
    </div>
  </footer>

</body>
</html>
