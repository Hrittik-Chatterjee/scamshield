# .dev.vars - Paste your keys here to test with real database and AI.
# Ensure this file is never committed to Git (it is added to .gitignore by default).

ADMIN_SECRET_KEY=dev-admin-key-change-in-production
SCRAPE_INGEST_KEY=dev-scrape-key-change-in-production

# AI API Keys
GROQ_API_KEY=paste_your_groq_api_key_here
